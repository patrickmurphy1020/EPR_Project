      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='1400' minheight='1400' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='32' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='98222' id='31' param='vert' type-v2='layout-flow' w='98770' x='615' y='889'>
                <zone forceUpdate='true' h='6667' id='24' type-v2='text' w='64231' x='0' y='0'>
                  <formatted-text>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='18'>NHS Acute Trust Digital Maturity &amp; Operational Performance Dashboard</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='14'>Exploring readiness, digital capability, workforce mix, and RTT performance</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='48753' id='7' is-fixed='true' name='Trust Readiness Ranking' w='49615' x='385' y='5667'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='solid' />
                    <format attr='border-width' value='1' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16470' id='26' type-v2='text' w='49615' x='50000' y='5667'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#003087' fontname='Arial' fontsize='8'>Key Findings</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>• Digital readiness varies widely</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'> across NHS acute trusts, with some highly prepared for EPR adoption and others significantly behind.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>• Higher digital maturity is generally linked to better RTT performance</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'>, suggesting digitally capable trusts may manage long waits more effectively.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>• Leadership and digital foundations are the strongest DMA pillars</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'>, while </run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>patient empowerment and population health</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'> are the weakest areas nationally.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>• Trusts with a stronger clinical workforce mix tend to show higher digital readiness</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'>, highlighting the role of clinical staff in driving digital adoption.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>• </run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'>Overall, the dashboard shows how </run>
                    <run bold='true' fontcolor='#003087' fontname='Arial' fontsize='8'>digital capability, workforce composition, and operational pressure interact</run>
                    <run fontcolor='#003087' fontname='Arial' fontsize='8'>, helping identify where targeted support or investment may be needed.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='249' h='32283' id='15' is-fixed='true' name='DMA Pillar Profile' w='49615' x='50000' y='22137'>
